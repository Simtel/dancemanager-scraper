{
  "name": "simtel/dancemanager-scraper",
  "description": "Scraper tournaments and groups from dancemanager.ru",
  "license": ["MIT"],
  "authors": [
    {
      "name": "Simtel",
      "email": "simuls@gmail.com"
    }
  ],
  "keywords": ["scraper", "dance", "tournament", "dancemanager"],
  "support": {
    "issues": "https://github.com/simtel/dancemanager-scraper/issues",
    "source": "https://github.com/simtel/dancemanager-scraper"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.2",
    "guzzlehttp/guzzle": "^7.0.1",
    "symfony/dom-crawler": "^7.4",
    "psr/cache": "^3.0",
    "psr/log": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Simtel\\DanceManagerScraper\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Simtel\\DanceManagerScraper\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "laravel/pint": "^1.2",
    "phpstan/phpstan": "^2.0",
    "symfony/css-selector": "^7.4"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "scripts": {
    "test": "phpunit --display-errors --no-coverage",
    "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-html build/coverage/html --coverage-text",
    "phpstan": "phpstan analyse --memory-limit=2G",
    "pint": "pint --parallel",
    "post-install": "composer install",
    "lint": ["@phpstan", "@pint"],
    "check": ["@test", "@phpstan", "@pint"]
  }
}